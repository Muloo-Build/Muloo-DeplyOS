generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EngagementType {
  AUDIT
  IMPLEMENTATION
  MIGRATION
  OPTIMISATION
  GUIDED_DEPLOYMENT
}

model Client {
  id                 String                    @id @default(cuid())
  name               String
  slug               String                    @unique
  clientRoles        String[]                  @default(["client"])
  parentClientId     String?
  hubSpotPortalId    String?
  industry           String?
  region             String?
  website            String?
  logoUrl            String?
  enrichedLogoUrl    String?
  companyOverview    String?
  additionalWebsites String[]
  linkedinUrl        String?
  facebookUrl        String?
  instagramUrl       String?
  xUrl               String?
  youtubeUrl         String?
  lastEnrichedAt     DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  parentClient       Client?                   @relation("ClientHierarchy", fields: [parentClientId], references: [id], onDelete: SetNull)
  childClients       Client[]                  @relation("ClientHierarchy")
  hubSpotPortal      HubSpotPortal?            @relation("ClientHubSpotPortal", fields: [hubSpotPortalId], references: [id], onDelete: SetNull)
  contacts           ClientContact[]
  projects           Project[]
  workflowRuns       WorkflowRun[]
  visibleToPartners  PartnerClientVisibility[] @relation("VisibilityTarget")
  visibleClients     PartnerClientVisibility[] @relation("VisibilityPartner")

  @@index([hubSpotPortalId])
}

model PartnerClientVisibility {
  id              String   @id @default(cuid())
  partnerClientId String
  clientId        String
  visibilityScope String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  partnerClient   Client   @relation("VisibilityPartner", fields: [partnerClientId], references: [id], onDelete: Cascade)
  client          Client   @relation("VisibilityTarget", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([partnerClientId, clientId])
  @@index([partnerClientId])
  @@index([clientId])
}

model ClientContact {
  id               String   @id @default(cuid())
  clientId         String
  firstName        String
  lastName         String?
  email            String
  title            String?
  canApproveQuotes Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, email])
  @@index([clientId, createdAt])
}

model WorkspaceUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  role      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceProviderConnection {
  id             String   @id @default(cuid())
  providerKey    String   @unique
  label          String
  connectionType String
  apiKey         String?
  defaultModel   String?
  endpointUrl    String?
  notes          String?
  isEnabled      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WorkspaceAiRouting {
  id            String   @id @default(cuid())
  workflowKey   String   @unique
  label         String
  providerKey   String
  modelOverride String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkspaceApiKey {
  id          String   @id @default(cuid())
  workspaceId String   @default("default")
  keyName     String
  keyValue    String
  label       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, keyName])
  @@index([workspaceId, updatedAt])
}

model WorkspaceEmailSettings {
  id            String   @id @default(cuid())
  providerLabel String   @default("SMTP")
  host          String?
  port          Int?
  secure        Boolean  @default(false)
  username      String?
  password      String?
  fromName      String?
  fromEmail     String?
  replyToEmail  String?
  enabled       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkspaceEmailOAuthConnection {
  id             String    @id @default(cuid())
  providerKey    String    @unique
  label          String
  clientId       String?
  clientSecret   String?
  redirectUri    String?
  scopes         String[]
  accessToken    String?
  refreshToken   String?
  tokenType      String?
  connectedEmail String?
  connectedName  String?
  tokenExpiresAt DateTime?
  gmailFilterLabel String?
  enabled        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WorkspaceTodo {
  id          String    @id @default(cuid())
  title       String
  notes       String?
  completed   Boolean   @default(false)
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WorkspaceCalendarConnection {
  id             String    @id @default(cuid())
  providerKey    String    @unique // "google_calendar"
  label          String
  clientId       String?
  clientSecret   String?
  redirectUri    String?
  scopes         String[]
  accessToken    String?
  refreshToken   String?
  tokenType      String?
  connectedEmail String?
  connectedName  String?
  tokenExpiresAt DateTime?
  enabled        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WorkspaceXeroConnection {
  id             String    @id @default(cuid())
  tenantId       String?
  tenantName     String?
  clientId       String?
  clientSecret   String?
  redirectUri    String?
  scopes         String[]
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  connectedEmail String?
  enabled        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WorkspaceDailySummary {
  id          String   @id @default(cuid())
  summaryDate DateTime @default(now())
  content     String   // AI-generated markdown summary
  generatedBy String   // providerKey used
  createdAt   DateTime @default(now())
}

model HubSpotPortal {
  id             String           @id @default(cuid())
  portalId       String           @unique
  displayName    String
  region         String?
  connected      Boolean          @default(false)
  accessToken    String?
  refreshToken   String?
  tokenType      String?
  scopes         String[]
  tokenExpiresAt DateTime?
  connectedEmail String?
  connectedName  String?
  hubDomain      String?
  installedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  clients        Client[]         @relation("ClientHubSpotPortal")
  projects       Project[]
  snapshots      PortalSnapshot[]
  workflowRuns   WorkflowRun[]
}

model Project {
  id                        String                  @id @default(cuid())
  name                      String
  status                    String                  @default("draft")
  quoteApprovalStatus       String                  @default("draft")
  quoteSharedAt             DateTime?
  quoteApprovedAt           DateTime?
  quoteApprovedByName       String?
  quoteApprovedByEmail      String?
  scopeLockedAt             DateTime?
  engagementType            EngagementType          @default(IMPLEMENTATION)
  includesPortalAudit       Boolean                 @default(false)
  owner                     String
  ownerEmail                String
  serviceFamily             String                  @default("hubspot_architecture")
  implementationApproach    String                  @default("pragmatic_poc")
  customerPlatformTier      String?
  platformTierSelections    Json?
  problemStatement          String?
  solutionRecommendation    String?
  scopeExecutiveSummary     String?
  clientChampionFirstName   String?
  clientChampionLastName    String?
  clientChampionEmail       String?
  clientQuestionnaireConfig Json?
  scopeType                 String?
  commercialBrief           String?
  deliveryTemplateId        String?
  selectedHubs              String[]
  currentPhase              String?
  clientId                  String
  portalId                  String
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  client                    Client                  @relation(fields: [clientId], references: [id])
  portal                    HubSpotPortal           @relation(fields: [portalId], references: [id])
  deliveryTemplate          DeliveryTemplate?       @relation(fields: [deliveryTemplateId], references: [id])
  discovery                 DiscoverySubmission[]
  discoveryEvidence         DiscoveryEvidence[]
  discoverySummary          DiscoverySummary?
  blueprint                 Blueprint?
  tasks                     Task[]
  messages                  ProjectMessage[]
  executionJobs             ExecutionJob[]
  clientAccess              ClientProjectAccess[]
  clientSubmissions         ClientInputSubmission[]
  quotes                    ProjectQuote[]
  workRequests              WorkRequest[]
  contextEntries            ProjectContext[]
  findings                  Finding[]
  recommendations           Recommendation[]
  workflowRuns              WorkflowRun[]
}

model ProjectContext {
  id          String   @id @default(cuid())
  projectId   String
  contextType String
  content     String   @db.Text
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, contextType])
  @@index([projectId, updatedAt])
}

model ProjectQuote {
  id              String    @id @default(cuid())
  projectId       String
  version         Int
  status          String    @default("shared")
  currency        String
  defaultRate     Float?
  phaseLines      Json
  productLines    Json
  totals          Json
  paymentSchedule Json
  context         Json?
  sharedAt        DateTime  @default(now())
  approvedAt      DateTime?
  approvedByName  String?
  approvedByEmail String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId, createdAt])
}

model ProjectMessage {
  id             String    @id @default(cuid())
  projectId      String
  senderType     String
  senderName     String
  body           String
  internalSeenAt DateTime?
  clientSeenAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model ProductCatalogItem {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  serviceFamily   String   @default("hubspot_architecture")
  category        String
  billingModel    String
  description     String?
  unitPrice       Float
  defaultQuantity Int      @default(1)
  unitLabel       String   @default("item")
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgentDefinition {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  purpose        String
  serviceFamily  String   @default("hubspot_architecture")
  provider       String
  model          String
  triggerType    String   @default("manual")
  approvalMode   String   @default("review_required")
  allowedActions String[]
  systemPrompt   String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tasks          Task[]
}

model DeliveryTemplate {
  id                  String                 @id @default(cuid())
  slug                String                 @unique
  name                String
  description         String?
  serviceFamily       String
  category            String
  scopeType           String
  recommendedHubs     String[]
  defaultPlannedHours Float?
  isActive            Boolean                @default(true)
  sortOrder           Int                    @default(0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  tasks               DeliveryTemplateTask[]
  projects            Project[]
}

model DeliveryTemplateTask {
  id               String           @id @default(cuid())
  templateId       String
  title            String
  description      String?
  category         String?
  executionType    String           @default("manual")
  priority         String           @default("medium")
  status           String           @default("todo")
  qaRequired       Boolean          @default(false)
  approvalRequired Boolean          @default(false)
  assigneeType     String?
  plannedHours     Float?
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  template         DeliveryTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model ClientPortalUser {
  id                          String                  @id @default(cuid())
  firstName                   String
  lastName                    String
  email                       String                  @unique
  password                    String
  inviteToken                 String?                 @unique
  inviteTokenExpiresAt        DateTime?
  inviteAcceptedAt            DateTime?
  passwordResetToken          String?                 @unique
  passwordResetTokenExpiresAt DateTime?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  access                      ClientProjectAccess[]
  submissions                 ClientInputSubmission[]
}

model ClientProjectAccess {
  id                    String           @id @default(cuid())
  userId                String
  projectId             String
  role                  String           @default("contributor")
  questionnaireAccess   Boolean          @default(true)
  assignedInputSections Int[]            @default([])
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  user                  ClientPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId, createdAt])
}

model WorkRequest {
  id                     String    @id @default(cuid())
  projectId              String?
  title                  String
  serviceFamily          String    @default("hubspot_architecture")
  requestType            String
  companyName            String?
  contactName            String
  contactEmail           String
  summary                String
  details                String?
  urgency                String?
  budgetRange            String?
  portalOrWebsite        String?
  internalNotes          String?
  commercialImpactHours  Float?
  commercialImpactFeeZar Float?
  deliveryTasks          Json?
  reviewedAt             DateTime?
  approvedAt             DateTime?
  approvedByName         String?
  rejectedAt             DateTime?
  deliveryAppendedAt     DateTime?
  links                  String[]
  status                 String    @default("new")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  project                Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tasks                  Task[]

  @@index([status, createdAt])
  @@index([projectId, createdAt])
}

model ClientInputSubmission {
  id            String           @id @default(cuid())
  projectId     String
  userId        String
  sessionNumber Int
  status        String           @default("draft")
  answers       Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          ClientPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, sessionNumber])
  @@index([projectId, sessionNumber, createdAt])
}

model DiscoverySubmission {
  id                    String   @id @default(cuid())
  projectId             String
  version               Int      @default(1)
  status                String   @default("draft")
  sections              Json?
  businessContext       Json?
  platformContext       Json?
  crmArchitecture       Json?
  salesRequirements     Json?
  marketingRequirements Json?
  serviceRequirements   Json?
  integrationsData      Json?
  governanceOps         Json?
  risksAssumptions      Json?
  completedSections     String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  project               Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, version])
}

model DiscoveryEvidence {
  id            String   @id @default(cuid())
  projectId     String
  sessionNumber Int
  evidenceType  String
  sourceLabel   String
  sourceUrl     String?
  content       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sessionNumber, createdAt])
}

model Blueprint {
  id          String          @id @default(cuid())
  projectId   String          @unique
  project     Project         @relation(fields: [projectId], references: [id])
  generatedAt DateTime        @default(now())
  tasks       BlueprintTask[]
}

model DiscoverySummary {
  id                       String   @id @default(cuid())
  projectId                String   @unique
  executiveSummary         String
  mainPainPoints           String[] @default([])
  recommendedApproach      String   @default("")
  whyThisApproach          String   @default("")
  phaseOneFocus            String   @default("")
  futureUpgradePath        String   @default("")
  inScopeItems             String[] @default([])
  outOfScopeItems          String[] @default([])
  supportingTools          String[] @default([])
  engagementTrack          String
  platformFit              String
  changeManagementRating   String
  dataReadinessRating      String
  scopeVolatilityRating    String
  missingInformation       String[]
  keyRisks                 String[]
  recommendedNextQuestions String[]
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BlueprintTask {
  id          String    @id @default(cuid())
  blueprintId String
  blueprint   Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  phase       Int
  phaseName   String
  name        String
  type        String
  effortHours Float
  order       Int

  @@index([blueprintId, phase, order])
}

model Task {
  id                     String           @id @default(cuid())
  projectId              String
  changeRequestId        String?
  scopeOrigin            String           @default("baseline")
  title                  String
  description            String?
  category               String?
  executionType          String           @default("manual")
  executionLaneRationale String?
  hubspotTierRequired    String?
  coworkBrief            String?
  manualInstructions     String?
  apiPayload             Json?
  validationStatus       String           @default("pending")
  validationEvidence     String?
  findingId              String?
  recommendationId       String?
  priority               String           @default("medium")
  status                 String           @default("draft")
  plannedHours           Float?
  actualHours            Float?
  qaRequired             Boolean          @default(false)
  approvalRequired       Boolean          @default(false)
  dependencyIds          String[]
  assigneeType           String?
  executionReadiness     String           @default("not_ready")
  assignedAgentId        String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  project                Project          @relation(fields: [projectId], references: [id])
  changeRequest          WorkRequest?     @relation(fields: [changeRequestId], references: [id], onDelete: SetNull)
  assignedAgent          AgentDefinition? @relation(fields: [assignedAgentId], references: [id])
  executionJobs          ExecutionJob[]
}

model ExecutionJob {
  id              String    @id @default(cuid())
  projectId       String
  taskId          String?
  jobType         String?
  moduleKey       String
  executionMethod String    @default("manual")
  mode            String    @default("dry-run")
  status          String    @default("queued")
  payload         Json?
  outputSummary   String?
  resultStatus    String?
  outputLog       String?
  errorLog        String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  project         Project   @relation(fields: [projectId], references: [id])
  task            Task?     @relation(fields: [taskId], references: [id])
}

model WorkflowRun {
  id           String         @id @default(cuid())
  workflowKey  String
  title        String
  projectId    String?
  clientId     String?
  portalId     String?
  providerKey  String?
  model        String?
  routeSource  String?
  requestText  String?
  summary      String?
  status       String         @default("queued")
  resultStatus String?
  outputLog    String?
  errorLog     String?
  payload      Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client       Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  portal       HubSpotPortal? @relation(fields: [portalId], references: [id], onDelete: SetNull)

  @@index([workflowKey, createdAt])
  @@index([projectId, createdAt])
  @@index([clientId, createdAt])
  @@index([portalId, createdAt])
}

model PortalSnapshot {
  id                   String        @id @default(cuid())
  portalId             String
  portal               HubSpotPortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  capturedAt           DateTime      @default(now())
  hubTier              String?
  activeHubs           String[]      @default([])
  contactPropertyCount Int?
  companyPropertyCount Int?
  dealPropertyCount    Int?
  ticketPropertyCount  Int?
  customObjectCount    Int?
  dealPipelineCount    Int?
  dealStageCount       Int?
  ticketPipelineCount  Int?
  activeUserCount      Int?
  teamCount            Int?
  activeListCount      Int?
  rawApiResponses      Json?
  createdAt            DateTime      @default(now())

  @@index([portalId, capturedAt])
}

model Finding {
  id                  String   @id @default(cuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  area                String
  severity            String
  source              String?
  category            String?
  title               String
  description         String
  quickWin            Boolean  @default(false)
  phaseRecommendation String   @default("next")
  evidence            Json?
  status              String   @default("open")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  recommendations     Recommendation[]

  @@index([projectId, area, severity])
}

model Recommendation {
  id                   String   @id @default(cuid())
  projectId            String
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  findingId            String?
  finding              Finding? @relation(fields: [findingId], references: [id], onDelete: SetNull)
  title                String
  area                 String
  type                 String
  phase                String   @default("next")
  rationale            String
  effort               String
  impact               String
  clientApprovalStatus String   @default("pending")
  linkedFindingIds     String[] @default([])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([projectId, area, type])
  @@index([findingId])
}
