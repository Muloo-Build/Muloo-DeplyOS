generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EngagementType {
  AUDIT
  IMPLEMENTATION
  MIGRATION
  OPTIMISATION
  GUIDED_DEPLOYMENT
}

model Client {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  industry           String?
  region             String?
  website            String?
  additionalWebsites String[]
  linkedinUrl        String?
  facebookUrl        String?
  instagramUrl       String?
  xUrl               String?
  youtubeUrl         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  projects           Project[]
}

model HubSpotPortal {
  id          String    @id @default(cuid())
  portalId    String    @unique
  displayName String
  region      String?
  connected   Boolean   @default(false)
  accessToken String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

model Project {
  id             String                @id @default(cuid())
  name           String
  status         String                @default("draft")
  engagementType EngagementType        @default(IMPLEMENTATION)
  owner          String
  ownerEmail     String
  clientChampionFirstName String?
  clientChampionLastName  String?
  clientChampionEmail     String?
  scopeType      String?
  commercialBrief String?
  deliveryTemplateId String?
  selectedHubs   String[]
  currentPhase   String?
  clientId       String
  portalId       String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  client         Client                @relation(fields: [clientId], references: [id])
  portal         HubSpotPortal         @relation(fields: [portalId], references: [id])
  deliveryTemplate DeliveryTemplate?   @relation(fields: [deliveryTemplateId], references: [id])
  discovery      DiscoverySubmission[]
  discoveryEvidence DiscoveryEvidence[]
  discoverySummary DiscoverySummary?
  blueprint      Blueprint?
  tasks          Task[]
  executionJobs  ExecutionJob[]
  clientAccess   ClientProjectAccess[]
  clientSubmissions ClientInputSubmission[]
  workRequests   WorkRequest[]
}

model ProductCatalogItem {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  serviceFamily   String   @default("hubspot_architecture")
  category        String
  billingModel    String
  description     String?
  unitPrice       Float
  defaultQuantity Int      @default(1)
  unitLabel       String   @default("item")
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgentDefinition {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  purpose        String
  provider       String
  model          String
  triggerType    String   @default("manual")
  approvalMode   String   @default("review_required")
  allowedActions String[]
  systemPrompt   String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DeliveryTemplate {
  id                 String                @id @default(cuid())
  slug               String                @unique
  name               String
  description        String?
  serviceFamily      String
  category           String
  scopeType          String
  recommendedHubs    String[]
  defaultPlannedHours Float?
  isActive           Boolean               @default(true)
  sortOrder          Int                   @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  tasks              DeliveryTemplateTask[]
  projects           Project[]
}

model DeliveryTemplateTask {
  id               String            @id @default(cuid())
  templateId       String
  title            String
  description      String?
  category         String?
  executionType    String            @default("manual")
  priority         String            @default("medium")
  status           String            @default("todo")
  qaRequired       Boolean           @default(false)
  approvalRequired Boolean           @default(false)
  assigneeType     String?
  plannedHours     Float?
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  template         DeliveryTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model ClientPortalUser {
  id                       String   @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String   @unique
  password                 String
  inviteToken              String?  @unique
  inviteTokenExpiresAt     DateTime?
  inviteAcceptedAt         DateTime?
  passwordResetToken       String?  @unique
  passwordResetTokenExpiresAt DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  access                   ClientProjectAccess[]
  submissions              ClientInputSubmission[]
}

model ClientProjectAccess {
  id        String           @id @default(cuid())
  userId    String
  projectId String
  role      String           @default("contributor")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      ClientPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId, createdAt])
}

model WorkRequest {
  id             String    @id @default(cuid())
  projectId      String?
  title          String
  serviceFamily  String    @default("hubspot_architecture")
  requestType    String
  companyName    String?
  contactName    String
  contactEmail   String
  summary        String
  details        String?
  urgency        String?
  budgetRange    String?
  portalOrWebsite String?
  links          String[]
  status         String    @default("new")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([projectId, createdAt])
}

model ClientInputSubmission {
  id           String           @id @default(cuid())
  projectId     String
  userId        String
  sessionNumber Int
  status        String          @default("draft")
  answers       Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          ClientPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, sessionNumber])
  @@index([projectId, sessionNumber, createdAt])
}

model DiscoverySubmission {
  id                    String   @id @default(cuid())
  projectId             String
  version               Int      @default(1)
  status                String   @default("draft")
  sections              Json?
  businessContext       Json?
  platformContext       Json?
  crmArchitecture       Json?
  salesRequirements     Json?
  marketingRequirements Json?
  serviceRequirements   Json?
  integrationsData      Json?
  governanceOps         Json?
  risksAssumptions      Json?
  completedSections     String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  project               Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, version])
}

model DiscoveryEvidence {
  id           String   @id @default(cuid())
  projectId     String
  sessionNumber Int
  evidenceType  String
  sourceLabel   String
  sourceUrl     String?
  content       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sessionNumber, createdAt])
}

model Blueprint {
  id          String          @id @default(cuid())
  projectId   String          @unique
  project     Project         @relation(fields: [projectId], references: [id])
  generatedAt DateTime        @default(now())
  tasks       BlueprintTask[]
}

model DiscoverySummary {
  id                     String   @id @default(cuid())
  projectId              String   @unique
  executiveSummary       String
  engagementTrack        String
  platformFit            String
  changeManagementRating String
  dataReadinessRating    String
  scopeVolatilityRating  String
  missingInformation     String[]
  keyRisks               String[]
  recommendedNextQuestions String[]
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  project                Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BlueprintTask {
  id          String    @id @default(cuid())
  blueprintId String
  blueprint   Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  phase       Int
  phaseName   String
  name        String
  type        String
  effortHours Float
  order       Int

  @@index([blueprintId, phase, order])
}

model Task {
  id               String         @id @default(cuid())
  projectId        String
  title            String
  description      String?
  category         String?
  executionType    String         @default("manual")
  priority         String         @default("medium")
  status           String         @default("draft")
  plannedHours     Float?
  actualHours      Float?
  qaRequired       Boolean        @default(false)
  approvalRequired Boolean        @default(false)
  dependencyIds    String[]
  assigneeType     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  project          Project        @relation(fields: [projectId], references: [id])
  executionJobs    ExecutionJob[]
}

model ExecutionJob {
  id              String    @id @default(cuid())
  projectId       String
  taskId          String?
  moduleKey       String
  executionMethod String    @default("manual")
  mode            String    @default("dry-run")
  status          String    @default("queued")
  payload         Json?
  resultStatus    String?
  outputLog       String?
  errorLog        String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  project         Project   @relation(fields: [projectId], references: [id])
  task            Task?     @relation(fields: [taskId], references: [id])
}
