{
  "name": "@muloo/api",
  "version": "0.2.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "node ../../scripts/run-with-root-env.mjs prisma migrate deploy",
    "generate": "prisma generate",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@muloo/browser-session-executor": "workspace:*",
    "@muloo/config": "workspace:*",
    "@muloo/executor": "workspace:*",
    "@muloo/file-system": "workspace:*",
    "@muloo/hubspot-client": "workspace:*",
    "@muloo/report-templates": "workspace:*",
    "@muloo/shared": "workspace:*",
    "@prisma/client": "5.22.0",
    "@types/bcrypt": "^6.0.0",
    "@types/nodemailer": "^7.0.11",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.22.3",
    "hono": "^4.12.9",
    "hono-rate-limiter": "^0.5.3",
    "ioredis": "^5.3.2",
    "nodemailer": "^8.0.3",
    "prisma": "5.22.0",
    "zod": "^3.24.2"
  }
}
