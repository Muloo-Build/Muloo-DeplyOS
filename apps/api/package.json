{
  "name": "@muloo/api",
  "version": "0.2.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "node ../../scripts/run-with-root-env.mjs prisma migrate deploy",
    "generate": "prisma generate",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@muloo/config": "workspace:*",
    "@muloo/executor": "workspace:*",
    "@muloo/file-system": "workspace:*",
    "@muloo/shared": "workspace:*",
    "@prisma/client": "5.22.0",
    "@types/nodemailer": "^7.0.11",
    "nodemailer": "^8.0.3",
    "prisma": "5.22.0",
    "zod": "^3.24.2"
  }
}
