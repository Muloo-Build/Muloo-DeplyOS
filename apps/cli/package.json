{
  "name": "@muloo/cli",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "muloo-deploy": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "cli": "node dist/index.js"
  },
  "dependencies": {
    "@muloo/config": "workspace:*",
    "@muloo/core": "workspace:*",
    "@muloo/executor": "workspace:*",
    "@muloo/file-system": "workspace:*",
    "@muloo/hubspot-client": "workspace:*"
  }
}
