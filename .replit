modules = ["nodejs-18", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install --no-frozen-lockfile && pnpm dev"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
APP_BASE_URL = "https://deploy.wearemulo.com"
MULOO_ALLOW_DESTRUCTIVE_ACTIONS = "false"
MULOO_ARTIFACT_DIR = "artifacts"
MULOO_EXECUTION_MODE = "dry-run"
NODE_ENV = "development"
API_PORT = "3001"

[userenv.development]
MULOO_DEV_BYPASS = "true"

[deployment]
deploymentTarget = "vm"
run = ["pnpm", "start"]
build = ["bash", "scripts/build.sh"]
