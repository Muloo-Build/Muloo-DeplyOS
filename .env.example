NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
# Repo root .env is the source of truth for local app runtime and `pnpm db:migrate`.
DATABASE_URL=
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_BASE_URL=
OPENAI_API_KEY=
MULOO_EXECUTION_MODE=dry-run
# Set MULOO_EXECUTION_MODE=guarded-apply only when explicitly testing the
# create-only contact property apply path with --apply --allow-create-only.
MULOO_ALLOW_DESTRUCTIVE_ACTIONS=false
MULOO_ARTIFACT_DIR=artifacts
