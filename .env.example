NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
# Repo root .env is the source of truth for local app runtime and `pnpm db:migrate`.
DATABASE_URL=
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_BASE_URL=
HUBSPOT_CLIENT_LOGIN_EVENT_ID=
HUBSPOT_CLIENT_QUOTE_VIEW_EVENT_ID=
HUBSPOT_CLIENT_DELIVERY_VIEW_EVENT_ID=
HUBSPOT_CLIENT_SUPPORT_VIEW_EVENT_ID=
HUBSPOT_CLIENT_REQUEST_WORK_VIEW_EVENT_ID=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GOOGLE_OAUTH_STATE_SECRET=
MULOO_EXECUTION_MODE=dry-run
# Set MULOO_EXECUTION_MODE=guarded-apply only when explicitly testing the
# create-only contact property apply path with --apply --allow-create-only.
MULOO_ALLOW_DESTRUCTIVE_ACTIONS=false
MULOO_ARTIFACT_DIR=artifacts
# Redis (required for job queue)
REDIS_URL=redis://localhost:6379
